# Deployment Webhook Handler Configuration
# Deploy this file to production/dev server at: /opt/subsora/.deploy.env

# Webhook security
WEBHOOK_SECRET=your-secret-key-here

# Docker configuration
DOCKER_STACK_NAME=subsora
DOCKER_REGISTRY=cicd.zerity.ru:55000
REGISTRY_USERNAME=your-docker-username
REGISTRY_PASSWORD=your-docker-password

# Service health check configuration
MAX_HEALTH_CHECK_RETRIES=30
HEALTH_CHECK_INTERVAL=2

# Webhook server configuration
WEBHOOK_PORT=5000
DEBUG=false
