# =============================================================================
# Общие правила для IDE, OS и локальных секретов
# =============================================================================

# Файлы операционных систем
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Файлы IDE и редакторов
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Локальные файлы .env с секретами
# Игнорировать все .env файлы во всех подпапках
**/.env
**/.env.local
**/.env.*.local

# Но НЕ игнорировать файлы-примеры
!**/.env.example

# Логи и временные файлы
logs/
*.log
*.log.*
*.swp
*.swo
*.tmp
*.bak
*.orig

# Docker (локальные оверрайды)
docker-compose.override.yml
docker-compose.local.yml

# =============================================================================
# Backend (Python)
# =============================================================================

# Виртуальные окружения
.venv/
venv/
env/

# Кэш и скомпилированные файлы Python
__pycache__/
*.py[cod]
*$py.class

# Директории с дистрибутивами/пакетами
build/
dist/
*.egg-info/
.eggs/

# Артефакты тестирования
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# SQLite базы данных (для локальной разработки/тестов)
*.db
*.sqlite
*.sqlite3

# Celery
celerybeat-schedule
*.pid

# Файлы pip
pip-log.txt

# =============================================================================
# Frontend (Node.js / Vite / React)
# =============================================================================

# Зависимости
node_modules/

# Сборка проекта
.vite/
.output/
.nuxt/

# Логи
npm-debug.log*
yarn-error.log
yarn-debug.log

# Отчеты о тестировании
coverage/

# =============================================================================
# Прочее
# =============================================================================

# Пользовательские временные файлы из вашего старого gitignore
scanner.py
tree.py
combined_clean_output.txt
subsora_backend.txt
whimvpn_frontend.txt