# .env.example

# ------------------------------------------------
# CORE APPLICATION SETTINGS
# ------------------------------------------------
# Имя проекта, используется в логах, именах и т.д.
PROJECT_NAME="Subsora"

# Режим работы приложения: "development", "staging", "production"
ENVIRONMENT="development"

# Включение/выключение режима отладки FastAPI
# В production должно быть False!
DEBUG=True

# ------------------------------------------------
# DATABASE
# ------------------------------------------------
# URL для подключения к основной базе данных.
# Для локальной разработки с Docker Compose: postgresql+asyncpg://postgres:postgres@db:5432/subsora
# Для внешней БД: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/subsora

# ------------------------------------------------
# SECURITY & JWT
# ------------------------------------------------
# Секретный ключ для подписи JWT-токенов. ДОЛЖЕН БЫТЬ СЛОЖНЫМ И УНИКАЛЬНЫМ.
# Можно сгенерировать командой: openssl rand -hex 32
JWT_SECRET_KEY=supersecret

# Алгоритм подписи токена
JWT_ALGORITHM="HS256"

# Время жизни access-токена в минутах
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ------------------------------------------------
# Список разрешенных источников (front-end).
# Указываются через запятую. Например: "http://localhost:3000,http://localhost:8080"
# В production здесь должен быть домен вашего фронтенда.
BACKEND_CORS_ORIGINS="http://localhost:3000,http://localhost:8000"

# ------------------------------------------------
# REDIS (Optional, for Caching/Celery Broker)
# ------------------------------------------------
# URL для подключения к Redis.
# Если не используется, оставьте пустым.
REDIS_URL=redis://redis:6379/0

# ------------------------------------------------
# EMAIL (Optional, for sending notifications)
# ------------------------------------------------
# Настройки для отправки почты через SMTP.
# Если не используется, оставьте пустыми.
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST=""
SMTP_USER=""
SMTP_PASSWORD=""
EMAILS_FROM_EMAIL=""

# ------------------------------------------------
# PAYMENT (Optional, Stripe)
# ------------------------------------------------
# Ключи для интеграции со Stripe.
# Если не используется, оставьте пустыми.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""


# Настройки панели Marzban
VPN_PANEL_URL="https://domain.com"
VPN_PANEL_PORT=8002
VPN_PANEL_USER="admin"
VPN_PANEL_PASSWORD="password"
VPN_PANEL_SSL=True

# Telegram bot
TELEGRAM_BOT_SECRET
TELEGRAM_BOT_TOKEN='***'