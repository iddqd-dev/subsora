meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{base_url}}/auth/login
  body: formUrlEncoded
  auth: none
}

body:form-urlencoded {
  username: {{user_email}}
  password: 123456
}

script:post-response {
  const data = res.getBody();
  if(data && data.access_token) {
    bru.setEnvVar("auth_token", data.access_token);
  }
}
